; vulkan-1.def
; Genere a partir de la liste reelle d'exports du loader systeme.
; Tout est forwarde vers vulkan-1-real.dll (copie du vrai vulkan-1.dll),
; SAUF les noms ci-dessous qui sont implementes/stubbes dans notre propre
; .cpp (vulkan_proc_dispatch.cpp) -- ceux-la ne doivent PAS apparaitre en
; forwarder ici, ils sont exportes directement par notre code.
;
; Liste des noms exclus (implémentés côté nous) :
;   vkGetInstanceProcAddr, vkGetDeviceProcAddr, vkCreateInstance,
;   vkEnumerateInstanceVersion, vkCmdBeginRendering, vkCmdEndRendering,
;   vkCmdSetRenderingAttachmentLocations, vkCmdSetRenderingInputAttachmentIndices,
;   vkGetDeviceImageMemoryRequirements, vkGetDeviceImageSparseMemoryRequirements,
;   vkGetDeviceBufferMemoryRequirements, vkCmdBindIndexBuffer2,
;   vkCopyMemoryToImage, vkCopyImageToMemory, vkCopyImageToImage,
;   vkTransitionImageLayout, vkCmdSetLineStipple, vkMapMemory2, vkUnmapMemory2,
;   vkGetRenderingAreaGranularity,
;   vkCreateImage, vkDestroyImage, vkCreateImageView, vkDestroyImageView,
;   vkAllocateCommandBuffers, vkFreeCommandBuffers,
;   vkEnumerateDeviceExtensionProperties, vkGetPhysicalDeviceFeatures2, vkCreateDevice
;   vkCreateGraphicsPipelines

